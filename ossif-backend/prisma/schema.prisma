// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Purchase {
  id          Int      @id @default(autoincrement())
  name        String
  category    String   @default("Autre")
  price       Float
  date        DateTime?
  monthsToPay Int
  lastPaidMonth String?
  link          String?
  expectedReceptionDate DateTime?
  reimbursementStartDate DateTime?
  skippedMonths Int      @default(0)
  termEmailSent Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Task {
  id          Int      @id @default(autoincrement())
  title       String
  date        DateTime
  isCompleted Boolean  @default(false)
  priority    String   @default("normal") // normal, urgent, super-urgent
  
  listId      Int?
  list        List?    @relation(fields: [listId], references: [id], onDelete: SetNull)

  description String?
  location    String?
  assignee    String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model List {
  id        Int      @id @default(autoincrement())
  name      String
  color     String   @default("stone")
  isDefault Boolean  @default(false)
  tasks     Task[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PushSubscription {
  id        Int      @id @default(autoincrement())
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}

model BattlePass {
  id        Int      @id @default(autoincrement())
  name      String
  isActive  Boolean  @default(false)
  progress  Int      @default(0) // Nombre de tâches complétées pour ce pass
  maxSteps  Int      @default(30)
  rewards   Reward[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Reward {
  id           Int        @id @default(autoincrement())
  battlePassId Int
  battlePass   BattlePass @relation(fields: [battlePassId], references: [id], onDelete: Cascade)
  step         Int        // Palier : 5, 10, 15, etc.
  description  String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Notification {
  id        Int      @id @default(autoincrement())
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}
